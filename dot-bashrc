alias coffee="caffeinate -disu"
alias net="NetworkQuality"
alias leaks="leaks -noContent -atExit --"

alias th="tmux -2 new-session -A -s home"
alias nv="nvim"
alias top="btop"

export PS1="\n\w\n❯ "
