################################################################################
#                                GENERAL SETTINGS                              #
################################################################################

# if not running interactively, don't do anything
[[ $- != *i* ]] && return


##################################################
#                Bash Configuration              #
##################################################

# setting up history options
HISTSIZE=500
HISTFILESIZE=500
HISTFILE="$XDG_DATA_HOME/bash/history"
shopt -s histappend
shopt -s cmdhist
HISTIGNORE="&:ls:[bf]g"
HISTCONTROL=ignoredups:ignorespace

# start up tmux session by default
if [ -z "$TMUX" ] && [ -z "$TERM_PROGRAM" ]; then
    tmux -2 new-session -A -s home
fi

##################################################
#                 Bash Keybindings               #
##################################################

bind '"5C": forward-word'
bind '"5D": backward-word'
bind '"5A": history-search-backward'
bind '"5B": history-search-forward'


##################################################
#                 Bash Completions               #
##################################################

if [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
fi

bind 'set show-all-if-ambiguous on'  # Show all completions if there's ambiguity
bind 'set completion-ignore-case on'  # Ignore case when completing
bind 'set menu-complete-display-prefix on'
complete -o nospace -o default -o bashdefault -o nospace -F _my_custom_completion my_command


################################################################################
#                               Developer Tools                                #
################################################################################

##################################################
#              Colima Configuration              #
##################################################

function colima() {
    if [[ $1 == "start" ]]; then
        command colima --ssh-config=false "$@"
    else
        command colima "$@"
    fi
}

##################################################
#              Zoxide Configuration              #
##################################################

eval "$(zoxide init bash)"

##################################################
#             Utilities Configuration            #
##################################################

# more versatile open command
function open() {
    if [ $# -eq 0 ]; then
        command open ./
    else
        command open "$@"
    fi
}


################################################################################
#                             Configure Bash Aliases                           #
################################################################################

alias cd="z"
alias cat="bat"

alias la="ls -AH"
alias ll="ls -lAHh --time-style=long-iso"
